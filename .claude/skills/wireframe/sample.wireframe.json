            "justify": "flex-start",
            "align": "center",
            "gap": 8
          },
          {
            "name": "ユーザーアイコン",
            "type": "icon",
            "width": 32,
            "height": 32,
            "_entity": "メンバー",
            "_attributes": [
              "アバター"
            ]
          }
        ]
      },
      {
        "name": "ツールバー",
        "direction": "horizontal",
        "height": 48,
        "children": [
          {
            "name": "検索",
            "type": "input",
            "placeholder": "タスクを検索...",
            "_note": "タイトル・担当者名でインクリメンタル検索"
          },
          {
            "name": "ステータスフィルター",
            "type": "select",
            "_entity": "タスク",
            "_attributes": [
              "ステータス"
            ]
          },
          {
            "name": "担当者フィルター",
            "type": "select",
            "_entity": "メンバー",
            "_attributes": [
              "名前"
            ]
          },
          {
            "name": "新規タスク",
            "type": "button",
            "_note": "クリックでタスク作成モーダルを開く"
          }
        ]
      },
      {
        "name": "フッター",
        "direction": "horizontal",
        "height": 40,
        "children": [
          {
            "name": "件数表示",
            "type": "text",
            "content": "全24件中 1-8件表示"
          },
          {
            "name": "ページネーション",
            "direction": "horizontal",
            "children": [
              {
                "name": "前へ",
                "type": "button"
              },
              {
                "name": "1",
                "type": "button"
              },
              {
                "name": "2",
                "type": "button"
              },
              {
                "name": "3",
                "type": "button"
              },
              {
                "name": "次へ",
                "type": "button"
              }
            ]
          }
        ]
      },
      {
        "name": "コンテナ",
        "direction": "vertical",
        "children": []
      },
      {
        "name": "ボタン",
        "type": "button"
      },
      {
        "name": "入力",
        "type": "input"
      },
      {
        "name": "セレクト",
        "type": "select"
      },
      {
        "name": "リンク",
        "type": "link"
      },
      {
        "name": "画像",
        "type": "table",
        "width": 200,
        "height": 150,
        "columns": [
          "C"
