{
  "name": "task-list",
  "view": {
    "context": "一覧",
    "primaryType": "table",
    "entities": [
      {
        "entity": "タスク",
        "role": "primary"
      },
      {
        "entity": "メンバー",
        "role": "filter"
      }
    ]
  },
  "viewport": {
    "width": 1280,
    "height": 800
  },
  "root": {
    "name": "ページ",
    "direction": "vertical",
    "children": [
      {
        "name": "ヘッダー",
        "direction": "horizontal",
        "height": 56,
        "children": [
          {
            "name": "ロゴ",
            "type": "text",
            "content": "TaskApp",
            "variant": "heading"
          },
          {
            "name": "ナビ",
            "direction": "horizontal",
            "grow": true,
            "children": [
              {
                "name": "プロジェクト",
                "type": "button"
              },
              {
                "name": "タスク",
                "type": "button"
              },
              {
                "name": "メンバー",
                "type": "button"
              }
