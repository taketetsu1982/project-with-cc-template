{
  "name": "task-list",
  "view": {
    "context": "一覧",
    "primaryType": "table",
    "entities": [
      {
        "entity": "タスク",
        "role": "primary",
        "attributes": [
          "タイトル: タスクの名前",
          "期限: 完了期限日",
          "ステータス: 未着手/進行中/完了",
          "優先度: 高/中/低",
          "担当者: 担当メンバー名",
          "説明: タスクの詳細説明",
          "作成日: タスク作成日時"
        ]
      },
      {
        "entity": "メンバー",
        "role": "related",
        "attributes": [
          "名前: メンバーの表示名",
          "メール: メールアドレス",
          "ロール: 管理者/メンバー/ゲスト"
        ]
      }
    ]
  },
  "viewport": {
    "width": 1280,
    "height": 800
  },
  "root": {
    "name": "ページ",
    "direction": "vertical",
    "children": [
      {
        "name": "ヘッダー",
        "direction": "horizontal",
        "height": 56,
        "children": [
          {
            "name": "ロゴ",
            "type": "text",
            "content": "TaskApp",
            "variant": "heading"
          },
          {
            "name": "ナビ",
            "direction": "horizontal",
            "grow": true,
            "children": [
              {
                "name": "プロジェクト",
                "type": "button"
              },
              {
                "name": "タスク",
                "type": "button"
              },
              {
                "name": "メンバー",
                "type": "button"
              }
            ]
          },
          {
            "name": "ユーザーアイコン",
            "type": "icon",
            "width": 32,
            "height": 32
          }
        ]
      },
      {
        "name": "ツールバー",
        "direction": "horizontal",
        "height": 48,
        "children": [
          {
            "name": "検索",
            "type": "input",
            "placeholder": "タスクを検索..."
          },
          {
            "name": "ステータスフィルター",
            "type": "select",
            "_entity": "タスク",
            "_attributes": [
              "ステータス"
            ]
          },
          {
            "name": "担当者フィルター",
            "type": "select",
            "_entity": "メンバー",
            "_attributes": [
              "名前"
            ]
          },
          {
            "name": "新規タスク",
            "type": "button"
          }
        ]
      },
      {
        "name": "メインコンテンツ",
        "direction": "vertical",
        "grow": true,
        "_entity": "タスク",
        "_attributes": [
          "タイトル",
          "期限",
          "ステータス",
          "優先度",
          "担当者"
        ],
        "children": [
          {
            "name": "タスクテーブル",
            "type": "table",
            "columns": [
              "タイトル",
              "期限",
              "ステータス",
              "優先度",
              "担当者"
            ],
            "rows": 8
          }
        ]
      },
      {
        "name": "フッター",
        "direction": "horizontal",
        "height": 40,
        "children": [
          {
            "name": "件数表示",
            "type": "text",
            "content": "全24件中 1-8件表示"
          },
          {
            "name": "ページネーション",
            "direction": "horizontal",
            "children": [
              {
                "name": "前へ",
                "type": "button"
              },
              {
                "name": "1",
                "type": "button"
              },
              {
                "name": "2",
                "type": "button"
              },
              {
                "name": "3",
                "type": "button"
              },
              {
                "name": "次へ",
                "type": "button"
              }
            ]
          }
        ]
      }
    ]
  }
}
