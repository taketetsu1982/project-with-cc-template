{
  "name": "Conceptual Model",
  "root": {
    "name": "プロジェクト管理",
    "direction": "vertical",
    "children": [
      {
        "name": "プロジェクト",
        "type": "entity",
        "attributes": ["名前: プロジェクト名", "説明: 概要テキスト", "ステータス: active/archived", "期限: 終了予定日"]
      },
      {
        "name": "タスク",
        "type": "entity",
        "attributes": ["タイトル: タスク名", "期限: 完了予定日", "ステータス: todo/doing/done", "優先度: high/medium/low", "担当者: メンバー参照"]
      },
      {
        "name": "メンバー",
        "type": "entity",
        "attributes": ["名前: 表示名", "メール: メールアドレス", "ロール: admin/member"]
      }
    ]
  },
  "views": [
    {
      "name": "task-list",
      "context": "一覧",
      "primaryType": "table",
      "entities": [
        { "entity": "タスク", "role": "primary" },
        { "entity": "メンバー", "role": "filter" }
      ]
    },
    {
      "name": "project-detail",
      "context": "詳細",
      "primaryType": "card",
      "entities": [
        { "entity": "プロジェクト", "role": "primary" },
        { "entity": "タスク", "role": "list" },
        { "entity": "メンバー", "role": "list" }
      ]
    }
  ]
}
